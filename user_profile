<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Green Bridge — Student Profile</title>

  <!-- Bootstrap 5 + Icons + Google Fonts (same as dashboard) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Fraunces:wght@400;700&display=swap" rel="stylesheet">

  <style>
    /* ----- EXACT design tokens, navbar, subnav from student dashboard ----- */
    :root {
      --forest:     #1a3a24;
      --forest-mid: #2d5a3d;
      --forest-lt:  #3d7a52;
      --sage:       #e8f0e9;
      --sage-mid:   #d0e0d3;
      --sage-dk:    #b8ccbc;
      --mint:       #4caf78;
      --mint-lt:    #7ecf9a;
      --gold:       #c9952a;
      --red-alert:  #c0392b;
      --blue-soft:  #2980b9;
      --bs-body-bg: #e8f0e9;
      --text:       #1e2d22;
      --text-md:    #4a6350;
      --text-lt:    #7a9882;
      --shadow-sm:  0 1px 4px rgba(26,58,36,0.08);
      --shadow:     0 4px 18px rgba(26,58,36,0.1);
      --shadow-lg:  0 12px 42px rgba(26,58,36,0.16);
      --radius:     12px;
      --radius-lg:  18px;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--sage);
      color: var(--text);
      min-height: 100vh;
    }

    h1, h2, h3, h4, h5 { font-family: 'Fraunces', serif; }

    /* ----- NAVBAR (exact) ----- */
    .gb-navbar {
      background: var(--forest) !important;
      height: 60px;
      padding: 0 28px;
      position: sticky;
      top: 0;
      z-index: 1030;
      box-shadow: 0 2px 12px rgba(0,0,0,0.22);
    }

    .gb-brand {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 21px;
      color: #fff !important;
      letter-spacing: -0.3px;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }

    .gb-search-wrap {
      flex: 1;
      max-width: 420px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      overflow: hidden;
      display: flex;
      transition: all .2s;
    }
    .gb-search-wrap:focus-within {
      background: rgba(255,255,255,0.18);
      border-color: rgba(255,255,255,0.35);
    }
    .gb-search-wrap input {
      background: transparent;
      border: none;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      outline: none;
      padding: 7px 14px;
      flex: 1;
    }
    .gb-search-wrap input::placeholder { color: rgba(255,255,255,0.45); }
    .gb-search-btn {
      background: var(--mint);
      border: none;
      color: #fff;
      font-weight: 600;
      font-size: 13px;
      padding: 0 16px;
      cursor: pointer;
      transition: background .2s;
      white-space: nowrap;
    }
    .gb-search-btn:hover { background: var(--mint-lt); }

    .nav-icon-btn {
      width: 38px; height: 38px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: rgba(255,255,255,0.85);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: all .2s;
      position: relative;
      font-size: 16px;
    }
    .nav-icon-btn:hover { background: rgba(255,255,255,0.2); color:#fff; }
    .notif-dot {
      position: absolute; top: 7px; right: 7px;
      width: 7px; height: 7px;
      background: var(--red-alert);
      border-radius: 50%;
      border: 1.5px solid var(--forest);
    }

    /* User chip (clickable — will open dropdown in real implementation) */
    .gb-user-chip {
      display: flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 10px;
      padding: 5px 12px 5px 6px;
      cursor: pointer;
      transition: all .2s;
      text-decoration: none;
      position: relative;
    }
    .gb-user-chip:hover { background: rgba(255,255,255,0.18); }
    .gb-avatar {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--mint), var(--forest-lt));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 13px; color:#fff;
      flex-shrink: 0;
    }
    .gb-user-name { font-size: 13px; font-weight: 600; color: #fff; line-height:1.2; }
    .gb-user-role { font-size: 10px; color: rgba(255,255,255,0.5); }

    /* DROPDOWN menu (simulated for demo) */
    .user-dropdown {
      position: absolute; top: 48px; right: 0; width: 180px;
      background: white; border-radius: 12px; border: 1px solid #dde6de;
      box-shadow: var(--shadow); display: none; z-index: 1100;
      overflow: hidden;
    }
    .user-dropdown.show { display: block; }
    .dropdown-item {
      padding: 12px 16px; font-size: 13px; color: var(--text);
      cursor: pointer; transition: background 0.1s;
      display: flex; align-items: center; gap: 10px;
    }
    .dropdown-item:hover { background: var(--sage); }
    .dropdown-item i { color: var(--forest-lt); width: 18px; }

    /* SUB-NAV (Profile item removed) */
    .gb-subnav {
      background: var(--forest-mid);
      padding: 0 28px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      gap: 2px;
      overflow-x: auto;
    }
    .gb-subnav::-webkit-scrollbar { display:none; }
    .gb-subnav-item {
      padding: 12px 18px;
      font-size: 13px;
      font-weight: 600;
      color: rgba(255,255,255,0.6);
      cursor: pointer;
      border-bottom: 2.5px solid transparent;
      transition: all .2s;
      white-space: nowrap;
    }
    .gb-subnav-item:hover { color: rgba(255,255,255,0.9); }
    .gb-subnav-item.active { color: #fff; border-bottom-color: var(--mint-lt); }

    /* Profile specific */
    .profile-header-card {
      background: #fff;
      border-radius: var(--radius-lg);
      border: 1px solid #dde6de;
      box-shadow: var(--shadow-sm);
      padding: 30px 28px;
    }
    .profile-avatar-large {
      width: 110px; height: 110px;
      background: linear-gradient(145deg, var(--forest), var(--forest-lt));
      border-radius: 28px;
      display: flex; align-items: center; justify-content: center;
      font-size: 48px; font-weight: 700; color: white;
      border: 4px solid var(--sage-mid);
      box-shadow: var(--shadow);
    }
    .profile-name {
      font-family: 'Fraunces', serif;
      font-size: 32px; font-weight: 700; color: var(--text);
      margin-bottom: 4px;
    }
    .profile-badge {
      background: var(--sage); color: var(--forest-mid); font-weight: 600;
      font-size: 13px; padding: 4px 14px; border-radius: 30px; display: inline-block;
    }

    /* info grid */
    .info-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 20px;
    }
    .info-item {
      background: #f8faf8; border-radius: 14px; padding: 14px 16px; border: 1px solid #dde6de;
    }
    .info-label {
      font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--text-lt); margin-bottom: 5px;
    }
    .info-value {
      font-weight: 700; font-size: 17px; color: var(--text);
    }

    /* stat cards (prominent) */
    .stat-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin: 16px 0 8px;
    }
    .stat-card {
      background: var(--forest); color: white; border-radius: 20px; padding: 18px 8px;
      text-align: center; box-shadow: var(--shadow); border: 1px solid var(--forest-lt);
    }
    .stat-number {
      font-family: 'Fraunces', serif; font-size: 32px; font-weight: 700; line-height: 1.1;
    }
    .stat-label {
      font-size: 12px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8;
    }

    /* certificate card */
    .certificate-card {
      background: #fafdfa; border-radius: 14px; padding: 18px;
      border: 1px solid #dde6de; transition: all .2s;
      display: flex; align-items: center; gap: 16px;
    }
    .certificate-card:hover { box-shadow: var(--shadow-sm); border-color: var(--sage-dk); background: #fff; }
    .cert-icon {
      width: 48px; height: 48px; background: var(--sage); border-radius: 12px;
      display: flex; align-items: center; justify-content: center; font-size: 24px; color: var(--forest);
    }
    .cert-title { font-weight: 700; font-size: 16px; color: var(--text); }
    .cert-meta { font-size: 12px; color: var(--text-lt); display: flex; gap: 12px; margin-top: 4px; }

    /* document items */
    .doc-item {
      display: flex; align-items: center; gap: 14px;
      padding: 14px 16px; background: #f8faf8; border-radius: 14px; border: 1px solid #dde6de;
      transition: all .2s; margin-bottom: 10px; cursor: pointer;
    }
    .doc-item:hover { background: var(--sage); border-color: var(--sage-dk); }
    .doc-icon {
      width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center;
      justify-content: center; font-size: 20px; flex-shrink: 0;
    }
    .doc-icon.pdf  { background: #ffe8e8; } .doc-icon.word { background: #e8eeff; }
    .doc-icon.cert { background: #e8f9ee; } .doc-icon.other { background: #f0f0f0; }
    .doc-status {
      font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }
    .doc-status.signed  { color:#1a6b3a; } .doc-status.pending { color:#7a5000; }
    .doc-status.live    { color:#1a6b3a; }

    .bio-text {
      font-size: 15px; line-height: 1.7; color: var(--text-md);
      background: #f8faf8; padding: 22px; border-radius: var(--radius); border: 1px solid #dde6de;
    }

    .btn-edit-profile {
      background: var(--forest); color: white; border: none; border-radius: 10px;
      padding: 10px 28px; font-weight: 600; font-size: 14px; transition: background .2s;
    }
    .btn-edit-profile:hover { background: var(--forest-mid); }

    .gb-card {
      background: #fff; border-radius: var(--radius-lg); padding: 22px 24px;
      border: 1px solid #dde6de; box-shadow: var(--shadow-sm);
    }
    .gb-card-title {
      font-family: 'Fraunces', serif; font-size: 18px; font-weight: 700; color: var(--text);
    }

    .container-profile { max-width: 1200px; margin: 0 auto; }

    /* skill chips */
    .skill-chip {
      display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:600;
      padding:6px 12px; border-radius:8px; border:1.5px solid;
    }
    .skill-excellent { background:#eafaf1; border-color:#90d4a8; color:#1a6b3a; }
    .skill-good      { background:#eaf2ff; border-color:#90b8e0; color:#1a40a0; }
    .skill-learning  { background:#fff8ea; border-color:#e0c070; color:#7a5000; }

    .btn-outline-forest {
      background:transparent; color:var(--forest); border:1.5px solid var(--forest);
      padding:6px 14px; border-radius:8px; font-weight:600; font-size:12px; cursor:pointer;
    }
    .btn-outline-forest:hover { background:var(--forest); color:#fff; }

    /* notification panel (minimal) */
    .notif-panel { position:fixed; top:62px; right:18px; width:340px; background:#fff; border-radius:var(--radius-lg); border:1px solid #dde6de; box-shadow:var(--shadow-lg); z-index:1050; display:none; }
    .notif-panel .notif-header { padding:14px 20px; border-bottom:1px solid #f0f4f1; display:flex; justify-content:space-between; align-items:center; }
    .notif-panel .notif-header h6 { font-family:'Fraunces',serif; font-size:16px; margin:0; }
    .notif-clear { font-size:11px; color:var(--forest-lt); cursor:pointer; font-weight:600; }
    .notif-panel.open { display:block; animation:gbFadeUp .2s ease; }
    @keyframes gbFadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

    .gb-toast-wrap { position:fixed; bottom:24px; right:24px; z-index:2000; display:flex; flex-direction:column; gap:8px; pointer-events:none; }
    .gb-toast { background: var(--forest); color:#fff; padding:13px 18px; border-radius:12px; font-size:13px; display:flex; align-items:center; gap:10px; box-shadow:var(--shadow-lg); border-left:4px solid var(--mint); transform:translateX(120%); transition:transform .35s; pointer-events:auto; max-width:320px; }
    .gb-toast.show { transform:translateX(0); }
    .gb-toast.error { border-left-color: var(--red-alert); }
    .gb-toast.warn  { border-left-color: var(--gold); }
  </style>
</head>

  // Certificates data
  const certificates = [
    { icon: '🌐', title: 'Web Development Fundamentals', issuer: 'DLSUD - CCS', date: 'Jan 2025', cred: 'WDF-239' },
    { icon: '📊', title: 'Data Analytics Virtual Internship', issuer: 'Accenture PH', date: 'Dec 2024', cred: 'ACN-4582' },
    { icon: '🔧', title: 'IoT Workshop Series', issuer: 'CEAT Makerspace', date: 'Nov 2024', cred: '12 hrs training' },
    { icon: '🤝', title: 'Leadership & Teamwork Badge', issuer: 'Green Bridge', date: 'Oct 2024', cred: 'peer endorsed' },
  ];

  function renderCertificates() {
    const container = document.getElementById('certificatesContainer');
    if (!container) return;
    container.innerHTML = certificates.map(cert => `
      <div class="certificate-card">
        <div class="cert-icon">${cert.icon}</div>
        <div class="cert-detail" style="flex:1">
          <div class="cert-title">${cert.title}</div>
          <div class="cert-meta"><span><i class="bi bi-building"></i> ${cert.issuer}</span><span><i class="bi bi-calendar3"></i> ${cert.date}</span></div>
          <div style="font-size:11px; color:var(--text-lt); margin-top:4px;">${cert.cred}</div>
        </div>
        <i class="bi bi-download" style="color:var(--forest-lt); cursor:pointer;" onclick="toast('Download certificate (demo)')"></i>
      </div>
    `).join('');
  }

  // Skills
  function renderSkills() {
    const skills = [
      { name:'React.js', level:'excellent' }, { name:'Laravel', level:'excellent' }, { name:'Python', level:'good' },
      { name:'SQL', level:'good' }, { name:'Docker', level:'learning' }, { name:'TensorFlow', level:'learning' },
      { name:'Teamwork', level:'excellent' }, { name:'Public speaking', level:'good' }
    ];
    const container = document.getElementById('skillsList');
    if (!container) return;
    container.innerHTML = skills.map(s => 
      `<span class="skill-chip skill-${s.level}"><i class="bi ${s.level==='excellent'?'bi-star-fill':s.level==='good'?'bi-circle-fill':'bi-circle'}"></i> ${s.name}</span>`
    ).join('');
  }

  // Documents
  function renderDocuments() {
    const container = document.getElementById('documentsList');
    if (!container) return;
    const typeIcon = { resume:'📕', waiver:'📗', moa:'📕', portfolio:'📘', other:'📄' };
    const typeClass = { resume:'pdf', waiver:'cert', moa:'pdf', portfolio:'word', other:'pdf' };
    container.innerHTML = S.documents.map(d => `
      <div class="doc-item" onclick="toast('Preview ${d.name} (demo)')">
        <div class="doc-icon ${typeClass[d.type]||'pdf'}">${typeIcon[d.type]||'📄'}</div>
        <div style="flex:1; min-width:0">
          <div style="font-size:14px; font-weight:500; color:var(--text);">${d.name}</div>
          <div style="font-size:11px; color:var(--text-lt); margin-top:2px">${d.type.toUpperCase()} · ${d.size} · ${d.date}</div>
        </div>
        <span class="doc-status ${d.status}">${d.status==='live'?'✓ Live':d.status==='signed'?'✓ Signed':'⏳ Pending'}</span>
        <i class="bi bi-three-dots-vertical" style="color:var(--text-lt);" onclick="event.stopPropagation();toast('More options')"></i>
      </div>
    `).join('');
  }

  // Toast
  function toast(msg, type='success') {
    const el = document.createElement('div');
    el.className = `gb-toast ${type}`;
    el.innerHTML = (type==='success'?'✅':type==='error'?'❌':'⚠️')+' '+msg;
    document.getElementById('toastContainer').appendChild(el);
    requestAnimationFrame(()=>requestAnimationFrame(()=>el.classList.add('show')));
    setTimeout(()=>{el.classList.remove('show');setTimeout(()=>el.remove(),400)},2800);
  }

  // Dropdown toggle
  window.toggleUserDropdown = function() {
    document.getElementById('userDropdown').classList.toggle('show');
  }

  // Notif
  window.toggleNotif = function() { document.getElementById('notifPanel').classList.toggle('open'); }
  window.clearNotifsDummy = function() { document.querySelector('.notif-dot').style.display='none'; toast('Notifications cleared','warn'); }
  
  // Close dropdown when clicking outside
  document.addEventListener('click', function(e) {
    const chip = document.getElementById('userChip');
    const dropdown = document.getElementById('userDropdown');
    if (chip && dropdown && !chip.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.remove('show');
    }
    // notif panel close
    const p = document.getElementById('notifPanel'), b = document.getElementById('notifBtn');
    if (p && b && !p.contains(e.target) && !b.contains(e.target)) p.classList.remove('open');
  });

  // Initial renders
  renderCertificates();
  renderSkills();
  renderDocuments();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Green Bridge | Student Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --evergreen: #344C3D;    /* Deep Forest */
            --moss: #738A6E;         /* Muted Green */
            --sage: #8EA58C;         /* Main Sage */
            --mint-sage: #BFCFBB;    /* Highlight Sage */
            --sage-hint: #DDE5DB;    /* Background */
        }

        body { 
            background-color: var(--sage-hint); 
            color: #2A3B30; 
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        /* Navbar Styling */
        .navbar { 
            background-color: var(--evergreen); 
            border-bottom: 2px solid var(--moss); 
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }
        .nav-link { 
            color: var(--mint-sage) !important; 
            transition: 0.3s; 
            font-weight: 500;
            padding: 0.5rem 1rem !important;
        }
        .nav-link:hover { 
            color: white !important; 
            background-color: rgba(255,255,255,0.1);
            border-radius: 8px;
        }

        /* Brand/Logo more visible */
        .navbar-brand {
            font-size: 1.8rem;          
            font-weight: 800;
            letter-spacing: 1px;
            color: white !important;
            text-shadow: 2px 2px 0 rgba(0,0,0,0.1);
        }
        .navbar-brand i {
            font-size: 2.2rem;
            color: var(--mint-sage);
            filter: drop-shadow(0 2px 2px rgba(0,0,0,0.2));
        }

        /* search bar - in first row beside icons */
        .search-wrapper {
            background-color: rgba(255,255,255,0.15);
            border-radius: 40px;
            padding: 0.2rem 0.2rem 0.2rem 1rem;
            border: 1px solid var(--moss);
            backdrop-filter: blur(2px);
            display: flex;
            align-items: center;
            gap: 0.25rem;
            width: 280px;
        }
        .search-wrapper input {
            background: transparent;
            border: none;
            color: white;
            font-size: 0.9rem;
            flex: 1;
            min-width: 140px;
            padding: 0.3rem 0;
        }
        .search-wrapper input::placeholder {
            color: var(--mint-sage);
            opacity: 0.8;
        }
        .search-wrapper input:focus {
            outline: none;
        }
        .search-wrapper button {
            background-color: var(--sage);
            border: none;
            border-radius: 40px;
            padding: 0.3rem 1rem;
            color: white;
            font-weight: 500;
            font-size: 0.85rem;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }
        .search-wrapper button:hover {
            background-color: var(--evergreen);
        }

        /* Second row navigation */
        .nav-row {
            background-color: rgba(0,0,0,0.15);
            padding: 0.3rem 0;
            border-top: 1px solid var(--moss);
        }
        .nav-row .nav-link {
            color: var(--mint-sage) !important;
            font-size: 0.95rem;
            padding: 0.4rem 1.2rem !important;
        }
        .nav-row .nav-link:hover {
            color: white !important;
            background-color: rgba(255,255,255,0.15);
            border-radius: 20px;
        }

        /* Sidebar Filter Card */
        .filter-card { 
            background-color: var(--evergreen); 
            color: white; 
            border-radius: 20px; 
            border: none;
            box-shadow: 0 8px 25px rgba(52, 76, 61, 0.2);
        }
        
        /* filter labels: stylish */
        .filter-header { 
            color: var(--mint-sage); 
            font-size: 0.8rem; 
            font-weight: 600; 
            text-transform: uppercase; 
            letter-spacing: 0.5px;
            font-family: 'Segoe UI', 'Inter', sans-serif;
            background: rgba(255,255,255,0.05);
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            display: inline-block;
        }

        /* Rounded Square Opportunity Cards */
        .opp-card {
            background-color: white;
            border: 2px solid transparent;
            border-radius: 20px;
            transition: all 0.3s ease;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .opp-card:hover {
            border-color: var(--moss);
            background-color: #f8faf8;
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(115, 138, 110, 0.15);
        }

        /* Bookmark styling - red when active */
        .bookmark-icon {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .bookmark-icon:hover {
            transform: scale(1.1);
        }
        .bookmark-icon.active {
            color: #dc3545 !important;
        }

        /* Buttons & Badges */
        .btn-details { 
            background-color: var(--evergreen); 
            color: var(--mint-sage); 
            border: 1px solid var(--moss); 
            border-radius: 10px; 
            font-weight: 600;
        }
        .btn-details:hover { 
            background-color: var(--moss); 
            color: white; 
        }

        .btn-apply { 
            background-color: var(--sage); 
            color: white; 
            border: none; 
            border-radius: 10px; 
        }
        .btn-apply:hover { 
            background-color: var(--evergreen); 
            color: white; 
        }
        
        .badge-type { background-color: var(--evergreen); color: var(--mint-sage); border-radius: 6px; }
        .badge-setup { background-color: var(--sage-hint); color: var(--evergreen); border-radius: 6px; }

        /* Custom Dropdowns */
        .form-select-dark {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            border: 1px solid var(--moss);
        }
        .form-select-dark option { color: black; }

        /* Profile role text */
        .profile-role {
            font-size: 0.7rem;
            color: var(--mint-sage);
            line-height: 1.2;
            opacity: 0.9;
        }

        /* apply filter button */
        .btn-filter-apply {
            background-color: var(--mint-sage);
            color: var(--evergreen);
            border: none;
            border-radius: 10px;
            font-weight: 700;
            padding: 0.6rem 1rem;
            width: 100%;
            transition: 0.2s;
        }
        .btn-filter-apply:hover {
            background-color: white;
            color: var(--evergreen);
        }

        /* sticky fix */
        .sticky-top-custom {
            top: 100px;
            position: sticky;
        }

        /* card actions */
        .card-actions {
            display: flex;
            gap: 8px;
            margin-top: auto;
        }
        .card-actions .btn {
            flex: 1;
            font-size: 0.9rem;
        }

        /* User name area - ensure it displays fully */
        .user-display {
            max-width: 180px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Dropdown icon spacing */
        .dropdown-item i {
            width: 1.3rem;
        }
    </style>
</head>
<body>

    <!-- NAVBAR with two rows -->
    <nav class="navbar sticky-top p-0">
        <!-- First row: Brand, Search, Icons, Profile -->
        <div class="container-fluid py-2" style="background-color: var(--evergreen);">
            <div class="container d-flex justify-content-between align-items-center">
                <!-- Brand -->
                <a class="navbar-brand fw-bold d-flex align-items-center" href="#">
                    <i class="bi bi-bridge fs-1 me-2"></i>
                    <span>GREEN BRIDGE</span>
                </a>
                
                <!-- Right section: Search bar, Icons, Profile -->
                <div class="d-flex align-items-center">
                    <!-- Search bar beside icons -->
                    <div class="search-wrapper me-3">
                        <input type="text" placeholder="Search opportunities...">
                        <button><i class="bi bi-search"></i> Go</button>
                    </div>
                    
                    <!-- Icons -->
                    <div class="d-flex me-3 gap-2">
                        <a href="#" class="nav-link px-2" title="Messages"><i class="bi bi-chat-dots fs-5"></i></a>
                        <a href="#" class="nav-link px-2" title="Email"><i class="bi bi-envelope-at fs-5"></i></a>
                        <a href="#" class="nav-link px-2" title="Notifications"><i class="bi bi-bell fs-5"></i></a>
                    </div>

                    <!-- Profile dropdown -->
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-white" data-bs-toggle="dropdown">
                            <img src="https://ui-avatars.com/api/?name=Juan+Dela+Cruz&background=8EA58C&color=fff" width="40" height="40" class="rounded-circle border-2 border-white">
                            <div class="ms-2 text-start d-none d-md-block user-display">
                                <span class="small fw-bold d-block">Juan Dela Cruz</span>
                                <span class="profile-role">Student</span>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                            <li><h6 class="dropdown-header">Student Account</h6></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>View Profile</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-people me-2"></i>Friend List</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-journal-text me-2"></i>Applications</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-clock-history me-2"></i>Activity</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Log Out</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Second row: Navigation links only -->
        <div class="container-fluid nav-row">
            <div class="container d-flex justify-content-start gap-2">
                <a href="#" class="nav-link px-3 fw-semibold">Home</a>
                <a href="#" class="nav-link px-3 fw-semibold">Community</a>
                <a href="#" class="nav-link px-3 fw-semibold">Applications</a>
                <a href="#" class="nav-link px-3 fw-semibold">Performance Report</a>
                <a href="#" class="nav-link px-3 fw-semibold">Bookmarks</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="row">
            
            <!-- sidebar filter card -->
            <aside class="col-lg-3">
                <div class="card filter-card p-4 sticky-top-custom">
                    <h5 class="mb-4 fw-bold"><i class="bi bi-funnel me-2"></i>Filters</h5>
                    
                    <div class="mb-4">
                        <span class="filter-header mb-2"><i class="bi bi-tag me-1"></i>Type</span>
                        <select class="form-select form-select-sm form-select-dark mt-2">
                            <option selected>All Types</option>
                            <option>Workshop</option>
                            <option>Internship</option>
                            <option>OJT</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <span class="filter-header mb-2"><i class="bi bi-geo-alt me-1"></i>Location</span>
                        <select class="form-select form-select-sm form-select-dark mt-2">
                            <option selected>All Regions</option>
                            <option>Manila</option>
                            <option>Cavite</option>
                            <option>Rizal</option>
                            <option>Laguna</option>
                            <option>Batangas</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <span class="filter-header mb-2"><i class="bi bi-building me-1"></i>Department</span>
                        <select class="form-select form-select-sm form-select-dark mt-2" id="collegeSelect" onchange="updateCourseOptions()">
                            <option value="">Select College</option>
                            <option value="CEAT">CEAT (Engineering)</option>
                            <option value="COED">COED (Education)</option>
                            <option value="CLAC">CLAC (Liberal Arts)</option>
                        </select>

                        <div id="courseContainer" class="mt-3" style="display: none;">
                            <span class="filter-header mb-2"><i class="bi bi-book me-1"></i>Course</span>
                            <select class="form-select form-select-sm form-select-dark mt-2" id="courseSelect"></select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <span class="filter-header mb-2"><i class="bi bi-laptop me-1"></i>Setup</span>
                        <div class="mt-2">
                            <div class="form-check small mb-1">
                                <input class="form-check-input" type="checkbox" id="remote" checked>
                                <label class="form-check-label" for="remote">Online / Remote</label>
                            </div>
                            <div class="form-check small">
                                <input class="form-check-input" type="checkbox" id="onsite">
                                <label class="form-check-label" for="onsite">Onsite / Face-to-Face</label>
                            </div>
                        </div>
                    </div>

                    <button class="btn-filter-apply">Apply Filters</button>
                </div>
            </aside>

            <main class="col-lg-9">
                <div class="mb-4">
                    <h3 class="fw-bold">Recommended for You</h3>
                    <p class="text-muted small">Based on your BS Computer Engineering profile</p>
                </div>

                <!-- Single example card for Recommended for You -->
                <div class="row g-4">
                    <div class="col-md-6 col-xl-4">
                        <div class="card opp-card p-4 shadow-sm">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge badge-type py-2 px-3">OJT</span>
                                <i class="bi bi-bookmark bookmark-icon text-muted" onclick="toggleBookmark(this)"></i>
                            </div>
                            <h5 class="fw-bold mb-1">Systems Analyst Trainee</h5>
                            <p class="small text-muted mb-3">Accenture Philippines • Manila</p>
                            
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <span class="badge badge-setup">Onsite</span>
                                <span class="badge badge-setup">CEAT</span>
                            </div>
                            
                            <div class="card-actions">
                                <button class="btn btn-details py-2">Details</button>
                                <button class="btn btn-apply py-2">Apply</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 mb-4">
                    <h4 class="fw-bold">Latest Opportunities</h4>
                </div>

                <!-- Single example card for Latest Opportunities -->
                <div class="row g-4">
                    <div class="col-md-6 col-xl-4">
                        <div class="card opp-card p-4 shadow-sm">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge badge-type py-2 px-3">Internship</span>
                                <i class="bi bi-bookmark bookmark-icon text-muted" onclick="toggleBookmark(this)"></i>
                            </div>
                            <h5 class="fw-bold mb-1">Data Analyst (Remote)</h5>
                            <p class="small text-muted mb-3">IBM • Manila</p>
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <span class="badge badge-setup">Remote</span>
                                <span class="badge badge-setup">CEAT/CLAC</span>
                            </div>
                            <div class="card-actions">
                                <button class="btn btn-details py-2">Details</button>
                                <button class="btn btn-apply py-2">Apply</button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        const courses = {
            "CEAT": ["Civil Engineering", "Computer Engineering", "Mechanical Engineering", "Electrical Engineering"],
            "COED": ["Elementary Education", "Secondary Education", "Physical Education"],
            "CLAC": ["Political Science", "Communication", "Psychology", "Journalism"]
        };

        function updateCourseOptions() {
            const college = document.getElementById('collegeSelect').value;
            const container = document.getElementById('courseContainer');
            const select = document.getElementById('courseSelect');

            select.innerHTML = '';

            if (college && courses[college]) {
                container.style.display = 'block';
                
                let allOption = document.createElement('option');
                allOption.value = "all";
                allOption.textContent = `Show All ${college} Courses`;
                select.appendChild(allOption);

                courses[college].forEach(course => {
                    let opt = document.createElement('option');
                    opt.value = course.toLowerCase().replace(/\s/g, '_');
                    opt.textContent = course;
                    select.appendChild(opt);
                });
            } else {
                container.style.display = 'none';
            }
        }

        // Bookmark toggle function - changes to red when clicked
        function toggleBookmark(element) {
            if (element.classList.contains('bi-bookmark')) {
                element.classList.remove('bi-bookmark', 'text-muted');
                element.classList.add('bi-bookmark-fill', 'active');
            } else {
                element.classList.remove('bi-bookmark-fill', 'active');
                element.classList.add('bi-bookmark', 'text-muted');
            }
        }

        // Prevent card click when clicking bookmark
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.bookmark-icon').forEach(icon => {
                icon.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            });
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

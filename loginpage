function toggleNotif() { document.getElementById('notifPanel').classList.toggle('open'); renderNotifications(); }
function closeNotifPanel() { document.getElementById('notifPanel').classList.remove('open'); }

function renderNotifications() {
  document.getElementById('notifList').innerHTML = S.notifications.map(n=>`
    <div class="notif-item ${n.read?'':'unread'}" onclick="markRead(${n.id})">
      <div class="notif-icon">${n.icon}</div>
      <div><div class="notif-text">${n.text}</div><div class="notif-time">${n.time}</div></div>
    </div>`).join('');
}

function markRead(id) { S.notifications.forEach(n=>{if(n.id===id)n.read=true;}); renderNotifications(); }

function clearNotifs() {
  S.notifications.forEach(n=>n.read=true);
  renderNotifications();
  document.querySelector('.notif-dot').style.display='none';
}


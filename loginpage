function toggleBookmark(id) {
  const o = S.opportunities.find(x=>x.id===id);
  o.bookmarked = !o.bookmarked;
  S.bookmarks  = S.opportunities.filter(x=>x.bookmarked);
  renderDiscover();
  toast(o.bookmarked ? 'Bookmarked!' : 'Bookmark removed', o.bookmarked?'success':'warn');
}

function renderBookmarks() {
  const el = document.getElementById('bookmarksGrid');
  el.innerHTML = S.bookmarks.length
    ? S.bookmarks.map(oppCardHtml).join('')
    : `<div class="col-12"><div class="empty-state"><h6>No bookmarks yet</h6><p>Click the bookmark icon on any opportunity to save it here.</p></div></div>`;
}


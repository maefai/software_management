      <div class="d-flex flex-wrap gap-1 justify-content-center mt-2">${o.tags.map(t=>`<span class="opp-tag">${t}</span>`).join('')}</div>
    </div>
    <div class="mb-3">
      <div class="detail-section-title">About This Opportunity</div>
      <p style="font-size:13px;color:var(--text-md);line-height:1.7">${o.description}</p>
    </div>
    <div class="mb-3">
      <div class="detail-section-title">Requirements</div>
      <p style="font-size:13px;color:var(--text-md);line-height:1.7">${o.requirements}</p>
    </div>
    <div class="row g-3 mb-3">
      <div class="col-6"><div class="detail-stat-box"><div class="detail-section-title">Duration</div><div style="font-weight:700;color:var(--forest)">${o.duration}</div></div></div>
      <div class="col-6"><div class="detail-stat-box"><div class="detail-section-title">Open Slots</div><div style="font-weight:700;color:var(--forest)">${o.slots} remaining</div></div></div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button class="btn-gb-secondary" onclick="toggleBookmark(${o.id});closeGbModal('oppDetailModal')">${o.bookmarked?'Remove Bookmark':'Bookmark'}</button>
      <button class="btn-gb-primary" onclick="closeGbModal('oppDetailModal');openApply(${o.id})" ${o.applied?'disabled':''}>
        ${o.applied?'✓ Already Applied':'Apply Now'}
      </button>
    </div>`;
  openGbModal('oppDetailModal');
}


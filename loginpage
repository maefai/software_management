function showOppDetail(id) {
  const o = S.opportunities.find(x=>x.id===id);
  document.getElementById('oppDetailContent').innerHTML = `
    <div class="text-center pb-3 mb-3" style="border-bottom:1px solid #f0f4f1">
      <div class="opp-detail-logo">🏢</div>
      <span class="opp-type-badge badge-${o.type.toLowerCase()}">${o.type}</span>

function oppCardHtml(o) {
  const badgeClass = 'badge-'+o.type.toLowerCase();
  return `<div class="col-12 col-md-6 col-xl-4">
    <div class="opp-card" id="opp-${o.id}">
      <div class="d-flex align-items-start justify-content-between mb-3">
        <span class="opp-type-badge ${badgeClass}">${o.type}</span>
        <button class="bookmark-btn ${o.bookmarked?'saved':''}" onclick="toggleBookmark(${o.id})" title="Bookmark">
          <i class="bi ${o.bookmarked?'bi-bookmark-fill':'bi-bookmark'}"></i>
        </button>
      </div>
      <div class="opp-title mb-1">${o.title}</div>
      <div class="opp-company mb-2">${o.company} · ${o.location}</div>
      <div class="d-flex flex-wrap gap-1 mb-3">${o.tags.map(t=>`<span class="opp-tag">${t}</span>`).join('')}</div>
      <div class="d-flex gap-2 mt-auto">
        <button class="btn-details" onclick="showOppDetail(${o.id})">Details</button>
        <button class="btn-apply ${o.applied?'applied':''}" onclick="${o.applied?'':('openApply('+o.id+')')}">
          ${o.applied?'✓ Applied':'Apply'}
        </button>
      </div>
    </div>
  </div>`;
}

function emptyState(icon, msg) {
  return `<div class="col-12"><div class="empty-state"><div class="es-icon">${icon}</div><p>${msg}</p></div></div>`;
}

function renderDiscover(filter={}) {
  let all = [...S.opportunities];
  if (filter.q) { const q=filter.q.toLowerCase(); all=all.filter(o=>o.title.toLowerCase().includes(q)||o.company.toLowerCase().includes(q)||o.tags.some(t=>t.toLowerCase().includes(q))); }
  if (filter.type)     all=all.filter(o=>o.type===filter.type);
  if (filter.location) all=all.filter(o=>o.location.includes(filter.location));
  if (filter.dept)     all=all.filter(o=>o.tags.some(t=>t.includes(filter.dept)));

  const showRemote = document.getElementById('chkRemote')?.checked ?? true;
  const showOnsite = document.getElementById('chkOnsite')?.checked ?? true;
  if (!showRemote) all=all.filter(o=>!o.setup.toLowerCase().includes('remote'));
  if (!showOnsite) all=all.filter(o=>!o.setup.toLowerCase().includes('onsite')&&!o.setup.toLowerCase().includes('hybrid'));

  const rec      = all.filter(o=>o.recommended);
  const latest   = all.filter(o=>!o.recommended && o.type!=='Workshop' && o.type!=='Scholarship');
  const workshops= all.filter(o=>o.type==='Workshop'||o.type==='Scholarship');

  document.getElementById('recommendedCards').innerHTML = rec.length ? rec.map(oppCardHtml).join('') : emptyState('No matches');
  document.getElementById('latestCards').innerHTML      = latest.length ? latest.map(oppCardHtml).join('') : emptyState('No results');
  document.getElementById('workshopCards').innerHTML    = workshops.length ? workshops.map(oppCardHtml).join('') : emptyState('No workshops');
}

function applyFilters() {
  renderDiscover({ type:document.getElementById('filterType')?.value, location:document.getElementById('filterLocation')?.value, dept:document.getElementById('filterDept')?.value });
}

function resetFilters() {
  ['filterType','filterLocation','filterDept','filterDuration'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('chkRemote').checked=true;
  document.getElementById('chkOnsite').checked=true;
  renderDiscover(); toast('Filters reset','warn');
}

function doSearch() {
  renderDiscover({ q: document.getElementById('searchInput').value.trim() });
}


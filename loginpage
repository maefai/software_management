  document.querySelectorAll('.gb-page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+name)?.classList.add('active');
  document.querySelectorAll('.gb-subnav-item').forEach(i=>i.classList.toggle('active',i.dataset.page===name));
  closeNotifPanel();
  if (name==='dashboard')   renderDashboard();
  if (name==='applications') renderApplications();
  if (name==='community')   renderCommunity();
  if (name==='performance') renderPerformance();
  if (name==='bookmarks')   renderBookmarks();
}


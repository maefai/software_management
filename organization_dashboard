<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Green Bridge | Organization Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --forest: #1a3a24;
            --forest-mid: #2d5a3d;
            --forest-lt: #3d7a52;
            --sage: #e8f0e9;
            --sage-mid: #d0e0d3;
            --sage-dk: #b8ccbc;
            --mint: #4caf78;
            --mint-lt: #7ecf9a;
            --mint-sage: #BFCFBB;
            --gold: #c9952a;
            --red-alert: #c0392b;
            --blue-soft: #2980b9;
            --bs-body-bg: #e8f0e9;
            --text: #1e2d22;
            --text-md: #4a6350;
            --text-lt: #7a9882;
            --moss: #738A6E;
            --sage-btn: #8EA58C;
        }

        body { 
            background-color: #2A3B30; 
            color: var(--text); 
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        /* Navbar Styling */
        .navbar { 
            background-color: var(--sage); 
            border-bottom: 2px solid var(--sage-mid); 
            padding-top: 0;
            padding-bottom: 0;
        }
        
        /* First row container */
        .navbar .container-fluid[style*="background-color"] { 
            background-color: var(--sage) !important; 
        }
        
        .nav-link { 
            color: var(--text) !important; 
            transition: 0.3s; 
            font-weight: 500;
            padding: 0.5rem 1rem !important;
        }
        .nav-link:hover { 
            color: var(--forest) !important; 
            background-color: rgba(0,0,0,0.05);
            border-radius: 8px;
        }

        /* Brand/Logo more visible */
        .navbar-brand {
            font-size: 1.8rem;          
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--text) !important;
            text-shadow: 2px 2px 0 rgba(255,255,255,0.3);
        }
        .navbar-brand i {
            font-size: 2.2rem;
            color: var(--forest);
            filter: drop-shadow(0 2px 2px rgba(0,0,0,0.1));
        }

        /* search bar - in first row beside icons */
        .search-wrapper {
            background-color: rgba(255,255,255,0.5);
            border-radius: 40px;
            padding: 0.2rem 0.2rem 0.2rem 1rem;
            border: 1px solid var(--sage-mid);
            backdrop-filter: blur(2px);
            display: flex;
            align-items: center;
            gap: 0.25rem;
            width: 280px;
        }
        .search-wrapper input {
            background: transparent;
            border: none;
            color: var(--text);
            font-size: 0.9rem;
            flex: 1;
            min-width: 140px;
            padding: 0.3rem 0;
        }
        .search-wrapper input::placeholder {
            color: var(--text-md);
            opacity: 0.8;
        }
        .search-wrapper input:focus {
            outline: none;
        }
        .search-wrapper button {
            background-color: var(--forest);
            border: none;
            border-radius: 40px;
            padding: 0.3rem 1rem;
            color: white;
            font-weight: 500;
            font-size: 0.85rem;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }
        .search-wrapper button:hover {
            background-color: var(--forest-mid);
            color: white;
        }

        /* Second row navigation */
        .nav-row {
            background-color: rgba(0,0,0,0.05);
            padding: 0.3rem 0;
            border-top: 1px solid var(--sage-mid);
        }
        .nav-row .nav-link {
            color: var(--text) !important;
            font-size: 0.95rem;
            padding: 0.4rem 1.2rem !important;
        }
        .nav-row .nav-link:hover {
            color: var(--forest) !important;
            background-color: rgba(0,0,0,0.08);
            border-radius: 20px;
        }

        /* Sidebar Filter Card */
        .filter-card { 
            background-color: var(--sage); 
            color: var(--text); 
            border-radius: 20px; 
            border: none;
            box-shadow: 0 8px 25px rgba(26, 58, 36, 0.2);
        }
        
        /* filter labels: stylish */
        .filter-header { 
            color: var(--text-md); 
            font-size: 0.8rem; 
            font-weight: 600; 
            text-transform: uppercase; 
            letter-spacing: 0.5px;
            font-family: 'Segoe UI', 'Inter', sans-serif;
            background: rgba(0,0,0,0.03);
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            display: inline-block;
        }

        /* Section Headers */
        h3.fw-bold {
            color: var(--sage) !important;
        }

        /* Applicant Cards - matching filter container color */
        .applicant-card {
            background-color: var(--sage);
            border: 2px solid transparent;
            border-radius: 20px;
            transition: all 0.3s ease;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 0 8px 25px rgba(26, 58, 36, 0.1);
        }
        .applicant-card:hover {
            border-color: var(--sage-dk);
            background-color: white;
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(26, 58, 36, 0.15);
        }

        /* Applicant Avatar */
        .applicant-avatar {
            width: 50px;
            height: 50px;
            background-color: var(--forest);
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2rem;
            border: 2px solid var(--sage-mid);
        }

        /* Course badge - updated to mint-sage */
        .course-badge {
            background-color: var(--mint-sage);
            color: var(--text);
            border-radius: 20px;
            padding: 0.25rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        /* Portfolio indicator */
        .portfolio-indicator {
            background-color: var(--gold);
            color: var(--text);
            border-radius: 20px;
            padding: 0.25rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .portfolio-indicator i {
            margin-right: 4px;
        }

        /* Resume indicator */
        .resume-indicator {
            background-color: var(--gold);
            color: var(--text);
            border-radius: 20px;
            padding: 0.25rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .resume-indicator i {
            margin-right: 4px;
        }

        /* Bookmark styling - red when active */
        .bookmark-icon {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .bookmark-icon:hover {
            transform: scale(1.1);
        }
        .bookmark-icon.active {
            color: var(--red-alert) !important;
        }

        /* Buttons */
        .btn-profile { 
            background-color: var(--forest); 
            color: white; 
            border: 1px solid var(--forest-lt); 
            border-radius: 10px; 
            font-weight: 600;
            flex: 1;
            font-size: 0.9rem;
            padding: 0.5rem 0;
        }
        .btn-profile:hover { 
            background-color: var(--forest-mid); 
            color: white; 
        }

        .btn-scout { 
            background-color: var(--sage-btn); 
            color: white; 
            border: none; 
            border-radius: 10px; 
            font-weight: 600;
            flex: 1;
            font-size: 0.9rem;
            padding: 0.5rem 0;
        }
        .btn-scout:hover { 
            background-color: var(--moss); 
            color: white; 
        }

        /* Custom Dropdowns */
        .form-select-dark {
            background-color: rgba(255,255,255,0.5);
            color: var(--text);
            border: 1px solid var(--sage-mid);
        }
        .form-select-dark option { color: var(--text); }

        /* Profile role text */
        .profile-role {
            font-size: 0.7rem;
            color: var(--text-md);
            line-height: 1.2;
            opacity: 0.9;
        }

        /* apply filter button - updated to match Details button */
        .btn-filter-apply {
            background-color: var(--forest);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 700;
            padding: 0.6rem 1rem;
            width: 100%;
            transition: 0.2s;
        }
        .btn-filter-apply:hover {
            background-color: var(--forest-mid);
            color: white;
        }

        /* sticky fix */
        .sticky-top-custom {
            top: 100px;
            position: sticky;
        }

        /* card actions */
        .card-actions {
            display: flex;
            gap: 8px;
            margin-top: 1rem;
        }

        /* User name area - ensure it displays fully */
        .user-display {
            max-width: 180px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Dropdown icon spacing */
        .dropdown-item i {
            width: 1.3rem;
        }
        
        /* Override the inline style background */
        .container-fluid[style*="background-color"] {
            background-color: var(--sage) !important;
        }

        /* Student info text */
        .student-meta {
            font-size: 0.75rem;
            color: var(--text-md);
        }
    </style>
</head>


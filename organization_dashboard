                                <button class="btn btn-scout py-1">Scout</button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        // Bookmark toggle function - changes to red when clicked
        function toggleBookmark(element) {
            if (element.classList.contains('bi-bookmark')) {
                element.classList.remove('bi-bookmark', 'text-muted');
                element.classList.add('bi-bookmark-fill', 'active');
            } else {
                element.classList.remove('bi-bookmark-fill', 'active');
                element.classList.add('bi-bookmark', 'text-muted');
            }
        }

        // Prevent card click when clicking bookmark
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.bookmark-icon').forEach(icon => {
                icon.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            });
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
